# agentic-platform — environment template (the source of truth for config).
#
# Copy to `.env` and fill in real values:  cp .env.example .env
# `.env` is git-ignored — NEVER commit real secrets; only this example is tracked.
#
# Settings load via Pydantic Settings (Ch 28) and FAIL FAST when a required
# variable is missing. docker-compose reads this file for the local stack.

# --- Mock mode -------------------------------------------------------------
# 1 = run offline: no model calls, no spend, deterministic stubs (tests rely on
# it; the MCP server and web chat both honor it). Set to 0 once you've wired real
# providers and supplied the keys below.
COMPANION_MOCK=1

# --- Model providers -------------------------------------------------------
# Primary provider. REQUIRED when COMPANION_MOCK=0. Default model: claude-opus-4-8.
ANTHROPIC_API_KEY=
# Secondary provider for routing / eval-judge chapters (optional).
OPENAI_API_KEY=

# --- Data layer ------------------------------------------------------------
# Postgres DSN. The compose default points at the local pgvector container.
DATABASE_URL=postgresql+psycopg://agent:agent@postgres:5432/agent
# Redis — Celery broker, result backend, and app cache.
REDIS_URL=redis://redis:6379/0

# --- Vector store ----------------------------------------------------------
# Local default (Chroma container). Set PINECONE_API_KEY to use the cloud option.
CHROMA_URL=http://chroma:8000
PINECONE_API_KEY=

# --- Auth ------------------------------------------------------------------
# JWT signing secret for the web app + API sessions. Generate a strong random
# value in real environments; leave blank to disable auth locally.
AUTH_SECRET=

# --- Observability ---------------------------------------------------------
# Where OTel traces go (Langfuse / Phoenix / a self-hosted collector). Optional.
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- AWS (deploy chapters only, Part VIII) ---------------------------------
AWS_PROFILE=
AWS_REGION=us-east-1

# --- Compose host ports (optional overrides) -------------------------------
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
CHROMA_PORT=8001
# Postgres container bootstrap (must match DATABASE_URL above).
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_DB=agent
