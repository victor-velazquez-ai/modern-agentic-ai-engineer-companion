# Keep the Docker build context lean and secret-free.
.git
.gitignore
**/__pycache__
**/*.pyc
.pytest_cache
.mypy_cache
.ruff_cache
.venv
venv

# Never ship env files or local state into the image.
.env
.env.*
!.env.example

# The frontend and infra are not part of the Python image.
web/node_modules
web/.next
infra/**/.terraform
infra/**/*.tfstate*

# Docs / notes.
*.md
