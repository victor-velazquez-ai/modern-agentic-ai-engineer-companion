# ─────────────────────────────────────────────────────────────────────────────
# agentic-platform/web — environment template
#
# Copy this to `.env.local` (git-ignored) and fill in real values:
#   cp .env.local.example .env.local
#
# These values are read ONLY in server code (route handlers, lib/auth, lib/api),
# never in the browser — secrets here never reach the client bundle.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the platform API (the FastAPI backend / app/). No trailing slash.
# The chat route proxies the backend's SSE run stream from here.
AGENT_API_URL=http://localhost:8000

# Bearer token the route handler sends to the API, if it requires auth.
# Leave blank to talk to a local backend with auth disabled.
AGENT_API_TOKEN=

# JWT signing secret for the web app's own sessions (matches AUTH_SECRET in
# the root .env). Server-side only — never prefix with NEXT_PUBLIC_.
AUTH_SECRET=

# Repo-wide offline switch: when "1", the chat route streams a canned reply and
# never calls the backend, so the UI runs with zero configuration.
COMPANION_MOCK=1
