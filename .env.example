# Companion environment — copy to .env and fill in only what you need.
# In the default MOCK mode you need NOTHING here. See docs/SETUP.md.

# --- Mock switch ---------------------------------------------------------------
# 1 = canned responses, free & offline & deterministic (default).
# 0 = hit live model APIs (requires a key below; notebooks print est. token cost).
COMPANION_MOCK=1

# --- Model providers -----------------------------------------------------------
ANTHROPIC_API_KEY=            # primary provider (book stack is Anthropic-first)
OPENAI_API_KEY=               # secondary — routing / eval-judge chapters

# --- Vector store (RAG, memory chapters) --------------------------------------
CHROMA_URL=                   # local default if blank; set for a remote Chroma
PINECONE_API_KEY=             # cloud vector store option (Ch 13)

# --- Data + cache services (only some chapters; via docker-compose) -----------
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/companion
REDIS_URL=redis://localhost:6379/0

# --- Web / capstone app --------------------------------------------------------
AUTH_SECRET=                  # JWT signing secret for the capstone web app

# --- Observability (Ch 23) -----------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=  # Langfuse / Phoenix / self-hosted collector

# --- AWS (deploy chapters only, Part VIII) ------------------------------------
AWS_PROFILE=
AWS_REGION=us-east-1
