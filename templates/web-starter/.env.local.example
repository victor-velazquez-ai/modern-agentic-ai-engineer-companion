# ─────────────────────────────────────────────────────────────────────────────
# web-starter — environment template
#
# Copy this file to `.env.local` (which is git-ignored) and fill in real values:
#
#     cp .env.local.example .env.local
#
# NEVER commit `.env.local`. These values are read ONLY in the server route
# handler (app/api/chat/route.ts), so nothing here ever reaches the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Which backend the chat route talks to. One of: "mock" | "anthropic" | "agent".
#   mock      — echo path; no key needed, the UI streams a canned reply (default)
#   anthropic — call the Anthropic API directly from the route handler
#   agent     — proxy your own backend (e.g. the fastapi-agent-service /v1/runs SSE)
# Leave it at "mock" to run the starter with zero configuration.
CHAT_BACKEND=mock

# ── Backend: anthropic ───────────────────────────────────────────────────────
# Required only when CHAT_BACKEND=anthropic.
# TODO: paste your Anthropic API key here (server-side only — never NEXT_PUBLIC_*).
ANTHROPIC_API_KEY=

# Model id. Default is the latest, most capable Claude model.
# TODO: change only if you deliberately want a different/cheaper model.
ANTHROPIC_MODEL=claude-opus-4-8

# ── Backend: agent ───────────────────────────────────────────────────────────
# Required only when CHAT_BACKEND=agent.
# Base URL of your agent service (no trailing slash). The route handler proxies
# the SSE stream from `${AGENT_API_URL}/v1/runs/{id}/stream?input=...`.
# TODO: point this at your running backend (see ../fastapi-agent-service).
AGENT_API_URL=http://localhost:8000

# Bearer token the route handler sends to your agent service, if it requires auth.
# TODO: set if your backend's auth dependency expects a token; leave blank otherwise.
AGENT_API_TOKEN=
