# .env.example — CI secret/variable CHECKLIST (not a place for real values)
#
# This template's workflows read NO secrets in their gating jobs: lint, type,
# test, and the eval-gate all run with COMPANION_MOCK=1, so PRs and forks need
# nothing here. The only job that uses a key is the OPT-IN nightly live-drift
# check (`eval-nightly` in eval-gate.yml).
#
# So this file is a CHECKLIST of which names a maintainer registers in GitHub —
# NOT a file you commit with real values. For the live job, set these as
# **secrets on the protected `eval-live` Environment** (Settings → Environments),
# never as plaintext in any committed file.
#
# Local note: if you run the eval harness on your machine, copy this to `.env`
# (which must be git-ignored) and fill real values there.

# --- Eval harness mode -------------------------------------------------------
# 1 = mock (free, deterministic; what CI uses). 0 = live (real API calls).
COMPANION_MOCK=1

# --- Live-mode secret (nightly drift check only) -----------------------------
# TODO: register this as a SECRET on the `eval-live` GitHub Environment.
#       Do NOT paste a real key here.
ANTHROPIC_API_KEY=

# --- Optional: add any other provider/judge keys your eval harness needs -----
# ▢ TODO: e.g. OPENAI_API_KEY=  (register as an Environment secret, leave blank here)
