# Keep the build context small and the image clean. Anything matched here is NOT
# sent to the Docker daemon, so it can never end up in an image layer.
# ▢ TODO: add any large data/asset dirs your project has (e.g. data/, models/).

# --- Secrets (never copy these into an image) ---------------------------------
.env
.env.*
!.env.example
*.pem
*.key

# --- Version control / CI -----------------------------------------------------
.git
.gitignore
.github
.dockerignore

# --- Python virtualenvs & caches ----------------------------------------------
.venv
venv
env
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.tox/
htmlcov/
.coverage
.coverage.*

# --- Tests & local-only tooling -----------------------------------------------
tests/
test/
.editorconfig
.pre-commit-config.yaml

# --- Docker compose files (the image doesn't need them) -----------------------
docker-compose.yml
compose.override.yml
compose.override.example.yml

# --- Editor / OS cruft --------------------------------------------------------
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# --- Docs (optional: keep README out of the runtime image) --------------------
README.md
*.md
