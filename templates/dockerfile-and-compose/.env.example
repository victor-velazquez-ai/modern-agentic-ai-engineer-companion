# Copy to .env and fill in only what you need. .env is git-ignored — never commit it.
# `docker compose` reads this file automatically (same directory as the compose file).
#
# In the default MOCK mode you need NOTHING here: the whole stack comes up and the
# api/worker run free, offline, and deterministically with no API key. Set
# COMPANION_MOCK=0 only when you want the service to hit the live model API
# (and have a key below).

# --- Mock switch ---------------------------------------------------------------
# 1 = api/worker use canned replies, free & offline & deterministic (default).
# 0 = hit the live model API (requires ANTHROPIC_API_KEY below).
COMPANION_MOCK=1

# --- Model provider (Anthropic-first) -----------------------------------------
# Required only when COMPANION_MOCK=0. Read by the api/worker, NOT by the
# infrastructure services.
ANTHROPIC_API_KEY=

# --- Service connection strings (consumed by api + worker) --------------------
# These point at the compose service names below — they work as-is inside the
# compose network. Override only if you run a service elsewhere. The username /
# password / db here MUST match the postgres service's environment block.
DATABASE_URL=postgresql+psycopg://agent:agent@postgres:5432/agent
REDIS_URL=redis://redis:6379/0
CHROMA_URL=http://chroma:8000

# --- Postgres credentials (consumed by the postgres service) ------------------
# Local-only development defaults. ▢ TODO: change these (and DATABASE_URL above)
# before using anywhere that is not your laptop.
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent
POSTGRES_DB=agent

# --- Host port mappings (optional) --------------------------------------------
# The left-hand side of each "ports:" mapping. Change if a port is already taken
# on your machine; container-internal ports stay the same.
API_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
CHROMA_PORT=8001
