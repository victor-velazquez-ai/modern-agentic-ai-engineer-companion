# Copy to .env and fill in only what you need. .env is git-ignored — never commit it.
#
# In the default MOCK mode you need NOTHING here: `make run` and `make test` work
# free, offline, and deterministically with no API key. Set COMPANION_MOCK=0 only
# when you want to hit the live model API (and have a key below).

# --- Mock switch ---------------------------------------------------------------
# 1 = canned reply, free & offline & deterministic (default).
# 0 = hit the live model API (requires ANTHROPIC_API_KEY below).
COMPANION_MOCK=1

# --- Model provider (Anthropic-first) -----------------------------------------
# Required only when COMPANION_MOCK=0.
ANTHROPIC_API_KEY=

# Override the default model id if you want a different one (optional).
# Default lives in src/app/llm.py (MODEL constant).
# MODEL=claude-opus-4-8

# --- TODO: your own settings --------------------------------------------------
# Add the environment variables your app needs here, and declare each one as a
# field in src/app/config.py so it's validated on startup. Examples:
# ▢ DATABASE_URL=
# ▢ MY_FEATURE_FLAG=
