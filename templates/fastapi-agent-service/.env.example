# Copy this file to `.env` and fill in real values. `.env` is git-ignored.
# NEVER commit real secrets. Only `.env.example` (this file) is committed.

# --- Runtime ---------------------------------------------------------------
APP_ENV=local
LOG_LEVEL=INFO

# --- Mock mode -------------------------------------------------------------
# 1 = stream canned tokens, no model call, no spend (default; tests rely on it).
# Set to 0 once you have wired a real agent and provided a real API key below.
COMPANION_MOCK=1

# --- Secrets (required only when COMPANION_MOCK=0) -------------------------
# ▢ TODO: paste your real key here in your local .env (not in this example file).
ANTHROPIC_API_KEY=

# Shared secret for the bearer-auth stub (core/security.py).
# Leave blank to disable auth locally; set a value to require a bearer token.
# ▢ TODO: replace the stub with your real IdP/JWT verification.
AUTH_SECRET=
