# Labeled golden set for the document-extraction pipeline (eval-harness format).
# One case per line: {"id", "input", "expected", "tags", "notes"}.
#   input    = the document source the extractor reads (same mock format as data/samples/).
#   expected = the human-labeled correct record (the fields a reviewer signed off on).
#   tags     = slice the accuracy score: `clean` / `repairable` are the easy/hard segments;
#              `must-dead-letter` are docs the pipeline MUST refuse to auto-post.
# The eval (evals/eval.py) runs the real extractor as the candidate, grades each produced
# record field-by-field against `expected`, and gates the mean accuracy against an explicit bar.
{"id": "inv-1001", "input": "invoice_number: INV-1001\nvendor: Acme Industrial Supply\ninvoice_date: 2026-03-04\ncurrency: USD\ntotal: 240.00\nLINE: Steel widget (10mm) | 2 | 60.00 | 120.00\nLINE: Brass gadget | 1 | 120.00 | 120.00", "expected": {"invoice_number": "INV-1001", "vendor": "Acme Industrial Supply", "invoice_date": "2026-03-04", "currency": "USD", "total": 240.00}, "tags": ["clean", "accuracy"], "notes": "Clean read; should validate first pass and match every labeled field."}
{"id": "inv-1005", "input": "invoice_number: INV-1005\nvendor: Umbrella Health Group\ninvoice_date: 2026-04-01\ncurrency: EUR\ntotal: 99.90\nLINE: Telehealth subscription | 1 | 99.90 | 99.90", "expected": {"invoice_number": "INV-1005", "vendor": "Umbrella Health Group", "invoice_date": "2026-04-01", "currency": "EUR", "total": 99.90}, "tags": ["clean", "accuracy"], "notes": "Non-USD currency; single line item that reconciles."}
{"id": "inv-1006", "input": "invoice_number: INV-1006\nvendor: Stark Components\ninvoice_date: 2026-04-12\ncurrency: USD\ntotal: 530.00\nLINE: Arc reactor casing | 1 | 500.00 | 500.00\nLINE: Mounting kit | 1 | 30.00 | 30.00", "expected": {"invoice_number": "INV-1006", "vendor": "Stark Components", "invoice_date": "2026-04-12", "currency": "USD", "total": 530.00}, "tags": ["clean", "accuracy"], "notes": "Two line items reconcile to total; straightforward."}
{"id": "inv-1002", "input": "invoice_number: INV-1002\nvendor: Globex Logistics\ninvoice_date: 03/05/2026\ncurrency: USD\ntotal: $1,450.00\nLINE: Freight forwarding | 1 | 1200.00 | 1200.00\nLINE: Customs handling | 1 | 250.00 | 250.00", "expected": {"invoice_number": "INV-1002", "vendor": "Globex Logistics", "invoice_date": "2026-03-05", "currency": "USD", "total": 1450.00}, "tags": ["repairable", "accuracy"], "notes": "US-format date + currency symbol; the labeled answer is the normalized form a repair turn should produce."}
{"id": "inv-1004", "input": "invoice_number: INV-1004\nvendor:\ninvoice_date: 2026-03-07\ncurrency: Dollars\ntotal: see attached", "expected": null, "tags": ["must-dead-letter", "safety"], "notes": "Unrecoverable read: blank vendor, bad currency, non-numeric total. Correct behavior is to DEAD-LETTER, never auto-post; expected=null means 'no record'."}
