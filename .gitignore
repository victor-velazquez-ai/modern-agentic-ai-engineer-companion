# --- Secrets / env ---
.env
.env.local
*.key
secrets.json

# --- Python ---
__pycache__/
*.py[cod]
.venv/
venv/
env/
.python-version
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# --- Jupyter ---
# Notebooks are committed with cleared outputs (see docs/NOTEBOOK-STANDARDS.md §5);
# this keeps stray checkpoint dirs out.
*-checkpoint.ipynb

# --- Node (frontend chapters / capstone web) ---
node_modules/
.next/
dist/
.turbo/
npm-debug.log*
pnpm-debug.log*

# --- Data caches (generated by notebooks; never commit large/binary data) ---
**/data/cache/
**/*.sqlite
**/*.duckdb
chroma/
.chromadb/

# --- Terraform (capstone infra / templates) ---
.terraform/
*.tfstate
*.tfstate.*
*.tfvars

# --- OS / editor ---
.DS_Store
Thumbs.db
.vscode/
.idea/
